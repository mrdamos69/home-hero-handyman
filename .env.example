# Copy this file to .env.local and fill in the values.
# The site runs without these — the estimate form falls back to demo mode
# and shows a simulated success message.

# Resend (https://resend.com) — used by /api/estimate to email form submissions
RESEND_API_KEY=

# Where form submissions should be delivered
ESTIMATE_TO_EMAIL=you@yourdomain.com

# Verified sender address in Resend (e.g. estimates@yourdomain.com)
ESTIMATE_FROM_EMAIL=onboarding@resend.dev

# Public site URL (used for sitemap, canonical URLs, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
